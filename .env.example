# hi-agent — environment variables
#
# Copy to `.env` and edit. The binary auto-loads `.env` at startup (via
# `dotenvy`), but existing process env takes precedence — so production
# deployments injecting env via systemd / k8s / compose are unaffected.
# Everything below is optional — the agent runs with all of these unset.

# ---------------------------------------------------------------------------
# Core
# ---------------------------------------------------------------------------

# Path to the claude-code binary (or any ACP-compatible agent).
# CLAUDE_CODE_BIN=claude-code
# Whitespace-separated extra args appended to the ACP launch.
# CLAUDE_CODE_ARGS=

# Logging filter — standard tracing-subscriber syntax.
# RUST_LOG=info

# MCP hub socket and shim binary. Override for split-binary / Docker layouts.
# HI_AGENT_MCP_SOCK=./data/mcp.sock
# HI_AGENT_SHIM_BIN=/path/to/hi-agent

# ---------------------------------------------------------------------------
# Voice — speech-to-text (POST /audio)
# ---------------------------------------------------------------------------
#
# Set STT_PROVIDER=volcengine to enable transcription. With it unset, POST
# /audio returns 501.

# STT_PROVIDER=volcengine
# VOLCENGINE_STT_API_KEY=
#
# Defaults target doubao 2.0 (hours) on the recommended optimized (async)
# endpoint. Override if you have a different resource or endpoint:
#   hours      : volc.seedasr.sauc.duration   (default)
#   concurrent : volc.seedasr.sauc.concurrent
# VOLCENGINE_STT_RESOURCE_ID=volc.seedasr.sauc.duration
# VOLCENGINE_STT_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async

# ---------------------------------------------------------------------------
# Voice — text-to-speech (speak channel="audio" → GET /audio)
# ---------------------------------------------------------------------------
#
# Set TTS_PROVIDER=volcengine to enable synthesis. With it unset, the speak
# MCP tool rejects channel="audio" with an error string — the agent's
# reasonable next step is to retry with channel="thought".

# TTS_PROVIDER=volcengine
# VOLCENGINE_TTS_APPID=
# VOLCENGINE_TTS_ACCESS_TOKEN=
# VOLCENGINE_TTS_CLUSTER=volcano_tts
# VOLCENGINE_TTS_VOICE=zh_female_qingxin
# VOLCENGINE_TTS_ENCODING=mp3
